# ── Stream / Channel Endpoints ────────────────────────────────────────────────
VITE_OWNCAST_URL=https://stream.example.com
VITE_OWNCAST_HLS_URL=https://stream.example.com/hls/stream.m3u8
VITE_OWNCAST_WS_URL=wss://stream.example.com/ws

VITE_YOUTUBE_LIVE_URL=https://www.youtube.com/embed/live_stream?channel=UCxxxxxxxx
VITE_YOUTUBE_CHAT_URL=https://www.youtube.com/live_chat?v=YOUR_VIDEO_ID

VITE_TWITCH_CHANNEL=your_channel

# ── OAuth Client IDs ─────────────────────────────────────────────────────────
# Register an app on each platform and paste your client ID below.
# Redirect URI for all: https://your-site.github.io/willowduster_site/
VITE_OAUTH_TWITCH_CLIENT_ID=
VITE_OAUTH_GOOGLE_CLIENT_ID=

# ── OAuth Redirect URI (auto-detected if empty) ─────────────────────────────
VITE_OAUTH_REDIRECT_URI=
